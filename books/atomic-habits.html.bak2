<!DOCTYPE html>
<html lang="vi"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>[edit] [edit] Atomic Habits — Sách tương tác</title>
<meta content="Phân tích chuyên sâu &quot;Atomic Habits&quot; (James Clear) — cách hệ thống nhỏ, đều, tích lũy thay đổi cuộc đời. Bởi Quang Ton." name="description">
<link href="../favicon.svg" rel="icon" type="image/svg+xml">
<link href="https://stop-and-think.pages.dev/atomic-habits" rel="canonical">
<meta content="article" property="og:type">
<meta content="Stop &amp; Think" property="og:site_name">
<meta content="vi_VN" property="og:locale">
<meta content="Atomic Habits — Sách tương tác | Stop &amp; Think" property="og:title">
<meta content="Phân tích chuyên sâu Atomic Habits của James Clear — 4 quy luật của thay đổi hành vi và vì sao hệ thống quan trọng hơn mục tiêu. Bởi Quang Ton." property="og:description">
<meta content="https://stop-and-think.pages.dev/atomic-habits" property="og:url">
<meta content="https://stop-and-think.pages.dev/og-image.svg" property="og:image">
<meta content="summary_large_image" name="twitter:card">
<link href="https://fonts.googleapis.com" rel="preconnect">
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,700;9..144,900&amp;family=JetBrains+Mono:wght@400;500;700&amp;family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
<style>
:root {
  --ink: #1a1410;
  --paper: #f5ede0;
  --paper-dark: #ebe1cf;
  --accent: #8b3a2b;
  --accent-2: #2d4a5c;
  --gold: #c4923c;
  --muted: #4a3f33;
  --line: #5e2418;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
em { font-style: normal; }

html { scroll-behavior: smooth; }

body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'Fraunces', Georgia, serif;
  font-size: 17px;
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

.nav-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  background: rgba(245, 237, 224, 0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--line);
  z-index: 100;
  padding: 14px 32px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.nav-logo {
  font-family: 'Fraunces', serif;
  font-weight: 700;
  font-size: 20px;
  letter-spacing: -0.02em;
  font-style: normal;
  color: var(--ink);
  text-decoration: none;
  transition: opacity 0.2s;
}
.nav-logo:hover { opacity: 0.7; }
.nav-logo span { color: var(--accent); }
.nav-links {
  display: flex;
  gap: 24px;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.nav-links a {
  color: var(--ink);
  text-decoration: none;
  transition: color 0.2s;
  cursor: pointer;
}
.nav-links a:hover { color: var(--accent); }
.nav-links a.active { color: var(--accent); font-weight: 600; }

.progress-bar {
  position: fixed;
  top: 56px; left: 0;
  height: 3px;
  background: var(--accent);
  z-index: 99;
  transition: width 0.1s;
}

.breadcrumb-bar {
  padding: 90px 8% 0;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
  position: relative;
  z-index: 2;
}
.breadcrumb-bar a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
.breadcrumb-bar a:hover { color: var(--accent); }
.breadcrumb-bar span { margin: 0 8px; opacity: 0.4; }
.breadcrumb-bar .current { color: var(--ink); font-weight: 600; }

.hero {
  min-height: 100vh;
  padding: 32px 8% 80px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  position: relative;
  border-bottom: 2px solid var(--line);
}
.hero-meta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 24px;
  display: flex;
  gap: 16px;
  align-items: center;
}
.hero-meta::before {
  content: '';
  width: 24px; height: 1px;
  background: var(--ink);
}
.hero h1 {
  font-family: 'Fraunces', serif;
  font-size: clamp(48px, 7vw, 110px);
  font-weight: 700;
  line-height: 0.95;
  letter-spacing: -0.04em;
  margin-bottom: 32px;
}
.hero h1 .italic {
  font-style: normal;
  color: var(--accent);
  font-weight: inherit;
}
.hero-sub {
  font-size: 24px;
  font-weight: 300;
  font-style: normal;
  color: var(--muted);
  max-width: 560px;
  margin-bottom: 48px;
  line-height: 1.5;
}
.hero-sub strong { color: var(--accent); font-weight: 500; }
.hero-author {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border-top: 1px solid var(--line);
  padding-top: 16px;
  display: inline-block;
}

.hero-visual {
  position: relative;
  height: 600px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-loop { width: 480px; height: 480px; position: relative; }
.hero-loop svg { width: 100%; height: 100%; overflow: visible; }
.hero-tag {
  position: absolute;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--paper);
  padding: 6px 12px;
}
.tag-1 { top: 40px; right: 20px; transform: rotate(8deg); }
.tag-2 { bottom: 60px; left: 0; transform: rotate(-6deg); }
.tag-3 { top: 50%; right: -10px; transform: rotate(-10deg); }

.section {
  padding: 100px 8%;
  border-bottom: 2px solid var(--line);
  position: relative;
}
.section-label {
  display: inline-block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 24px;
  padding-left: 36px;
  position: relative;
}
.section-label::before {
  content: '◆';
  position: absolute;
  left: 0;
  color: var(--accent);
}
.section-title {
  font-family: 'Fraunces', serif;
  font-size: clamp(36px, 5vw, 72px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.025em;
  margin-bottom: 32px;
  max-width: 1100px;
}
.section-title em {
  font-style: normal;
  color: var(--accent);
  font-weight: inherit;
}

.thesis-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  max-width: 1300px;
}
.thesis-title-small {
  font-family: 'Fraunces', serif;
  font-size: clamp(28px, 3.5vw, 44px);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.2;
  margin-bottom: 24px;
}
.thesis-viz {
  position: relative;
  width: 100%;
  max-width: 520px;
  aspect-ratio: 1;
  margin: 0 auto;
}
.thesis-viz svg { width: 100%; height: 100%; overflow: visible; }
@media (max-width: 800px) {
  .thesis-grid { grid-template-columns: 1fr; gap: 64px; }
  .thesis-viz { max-width: 400px; }
}

.section-intro {
  font-family: 'Fraunces', Georgia, serif;
  font-size: 22px;
  font-weight: 300;
  line-height: 1.55;
  color: var(--muted);
  max-width: 760px;
  margin-bottom: 56px;
}
.section-intro strong { color: var(--accent); font-weight: 500; }

.thesis-quote {
  background: var(--ink);
  color: var(--paper);
  padding: 80px 8%;
  text-align: center;
  border-bottom: 2px solid var(--line);
}
.thesis-mark {
  font-family: 'Fraunces', serif;
  font-size: 96px;
  color: var(--gold);
  line-height: 0.5;
  margin-bottom: 24px;
  font-weight: 700;
}
.thesis-text {
  font-family: 'Fraunces', serif;
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 300;
  font-style: normal;
  line-height: 1.3;
  max-width: 1000px;
  margin: 0 auto 32px;
}
.thesis-text em {
  color: var(--gold);
  font-style: normal;
  font-weight: 700;
}
.thesis-author {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
}

/* ============ HABIT LOOP DIAGRAM ============ */
.loop-diagram {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin: 48px 0;
}
.loop-node {
  padding: 28px 20px;
  background: var(--paper);
  border: 2px solid var(--ink);
  text-align: center;
  position: relative;
}
.loop-node:nth-child(1) { background: var(--paper-dark); }
.loop-node:nth-child(2) { background: var(--gold); color: var(--ink); }
.loop-node:nth-child(3) { background: var(--accent); color: var(--paper); }
.loop-node:nth-child(4) { background: var(--accent-2); color: var(--paper); }
.loop-node-num {
  font-family: 'Fraunces', serif;
  font-size: 36px;
  font-weight: 700;
  font-style: normal;
  line-height: 1;
  margin-bottom: 8px;
  opacity: 0.5;
}
.loop-node-stage {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 12px;
  opacity: 0.7;
}
.loop-node-title {
  font-family: 'Fraunces', serif;
  font-size: 22px;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 10px;
}
.loop-node-desc {
  font-size: 13px;
  font-weight: 300;
  line-height: 1.5;
  opacity: 0.95;
}

/* ============ FOUR LAWS GRID ============ */
.laws-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  margin: 40px 0;
}
.law-card {
  padding: 36px;
  border: 2px solid var(--ink);
  background: var(--paper);
  position: relative;
}
.law-card:nth-child(1) { border-color: var(--accent); }
.law-card:nth-child(2) { border-color: var(--gold); background: var(--paper-dark); }
.law-card:nth-child(3) { border-color: var(--accent); background: var(--paper-dark); }
.law-card:nth-child(4) { border-color: var(--gold); }
.law-num {
  position: absolute;
  top: -16px;
  left: 24px;
  background: var(--ink);
  color: var(--paper);
  padding: 4px 16px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
}
.law-name {
  font-family: 'Fraunces', serif;
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 8px;
  margin-top: 6px;
}
.law-name em { font-style: normal; color: var(--accent); }
.law-stage {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 16px;
}
.law-desc {
  font-size: 16px;
  font-weight: 300;
  line-height: 1.6;
  color: var(--muted);
  margin-bottom: 16px;
}
.law-desc strong { color: var(--accent); font-weight: 500; }
.law-tactic {
  padding: 14px 16px;
  background: var(--ink);
  color: var(--paper);
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  line-height: 1.5;
  letter-spacing: 0.05em;
}
.law-inverse {
  margin-top: 12px;
  padding: 12px 16px;
  background: rgba(139,58,43,0.08);
  border-left: 3px solid var(--accent);
  font-size: 14px;
  line-height: 1.5;
  color: var(--muted);
}
.law-inverse strong { color: var(--accent); font-weight: 500; }

/* ============ IDENTITY LAYERS ============ */
.identity-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 16px;
  align-items: center;
  margin: 56px 0;
}
.identity-col {
  border: 2px solid var(--ink);
  padding: 32px;
}
.identity-col.outcome { background: var(--paper); }
.identity-col.identity { background: var(--ink); color: var(--paper); }
.identity-arrow { font-size: 32px; color: var(--ink); text-align: center; }
.identity-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 12px;
  opacity: 0.7;
}
.identity-name {
  font-family: 'Fraunces', serif;
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 8px;
}
.identity-list { list-style: none; padding: 0; margin-top: 16px; }
.identity-list li {
  padding: 10px 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
  font-size: 15px;
  font-weight: 300;
  line-height: 1.5;
}
.identity-col.identity .identity-list li { border-bottom-color: rgba(255,255,255,0.1); }

/* ============ ONE PERCENT VISUAL ============ */
.percent-box {
  margin-top: 40px;
  padding: 32px;
  background: var(--paper-dark);
  border-left: 4px solid var(--gold);
}
.percent-title {
  font-family: 'Fraunces', serif;
  font-size: 22px;
  font-weight: 700;
  font-style: normal;
  margin-bottom: 12px;
}

/* ============ CHAPTERS ============ */
.rule-section { margin-bottom: 64px; }
.rule-header {
  background: var(--ink);
  color: var(--paper);
  padding: 24px 32px;
  margin-bottom: 24px;
  position: relative;
}
.rule-header::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6px;
  background: var(--accent);
}
.rule-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--gold);
  margin-bottom: 6px;
}
.rule-title {
  font-family: 'Fraunces', serif;
  font-size: 28px;
  font-weight: 700;
  font-style: normal;
  line-height: 1.2;
  margin-bottom: 6px;
}
.rule-sub {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  opacity: 0.7;
}
.chapter-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 16px;
}
.chapter-card {
  border: 1.5px solid var(--ink);
  padding: 24px;
  background: var(--paper);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.chapter-card:hover {
  transform: translate(-3px, -3px);
  box-shadow: 6px 6px 0 var(--accent);
  background: var(--paper-dark);
}
.chapter-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--accent);
  margin-bottom: 8px;
}
.chapter-title {
  font-family: 'Fraunces', serif;
  font-size: 20px;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 10px;
}
.chapter-desc {
  font-size: 16px;
  font-weight: 300;
  line-height: 1.6;
  color: var(--muted);
}
.chapter-desc strong { color: var(--accent); font-weight: 500; }
.chapter-key {
  display: inline-block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--paper);
  padding: 3px 8px;
  margin: 8px 4px 0 0;
}

/* ============ FLASHCARDS ============ */
/* Interactive Flashcards (Think Again style) */
.flashcard-container { max-width: 720px; margin: 32px auto; }
.flashcard-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.1em; color: var(--muted); }
.flashcard-counter { color: var(--muted); letter-spacing: 0.1em; }
.flashcard-counter strong { color: var(--ink); font-size: 14px; }
.flashcard { position: relative; width: 100%; min-height: 280px; perspective: 1500px; cursor: pointer; background: transparent; border: none; padding: 0; transition: none; transform: none; box-shadow: none; display: block; }
.flashcard:hover { transform: none; box-shadow: none; }
.flashcard-face { position: absolute; inset: 0; backface-visibility: hidden; padding: 36px 32px; border: 2px solid var(--ink); display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; transition: transform 0.6s; }
.flashcard-front { background: var(--paper-dark); transform: rotateY(0deg); }
.flashcard-back { background: var(--accent-2); color: var(--paper); transform: rotateY(180deg); }
.flashcard.flipped .flashcard-front { transform: rotateY(180deg); }
.flashcard.flipped .flashcard-back { transform: rotateY(360deg); }
.flashcard-tag { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; color: var(--accent-2); margin-bottom: 16px; text-transform: uppercase; }
.flashcard-back .flashcard-tag { color: var(--paper); opacity: 0.8; }
.flashcard-question { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 600; line-height: 1.35; margin-bottom: 16px; color: var(--ink); }
.flashcard-answer { font-size: 17px; line-height: 1.55; color: var(--paper); margin-bottom: 16px; max-width: 580px; }
.flashcard-hint { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; opacity: 0.6; text-transform: uppercase; }
.flashcard-nav { display: flex; gap: 12px; justify-content: center; margin-top: 24px; flex-wrap: wrap; }
.fcq-btn { padding: 12px 22px; border: 1.5px solid var(--ink); background: var(--paper); color: var(--ink); font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.fcq-btn:hover { background: var(--ink); color: var(--paper); }
.fcq-btn.outline { background: transparent; }
.fcq-btn.accent { background: var(--accent-2); color: var(--paper); border-color: var(--accent-2); }
.fcq-btn.accent:hover { background: var(--ink); border-color: var(--ink); }

/* ============ QUIZ ============ */
.quiz-container { max-width: 720px; margin: 32px auto; padding: 36px 32px; background: var(--paper-dark); border: 2px solid var(--ink); }
.quiz-progress { display: flex; justify-content: space-between; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 12px; }
.quiz-bar { height: 4px; background: rgba(26,20,16,0.15); margin-bottom: 24px; }
.quiz-bar-fill { height: 100%; background: var(--accent-2); transition: width 0.4s; }
.quiz-question { font-family: 'Fraunces', serif; font-size: 21px; font-weight: 600; line-height: 1.4; margin-bottom: 24px; color: var(--ink); margin-top: 0; }
.quiz-options { display: flex; flex-direction: column; gap: 10px; }
.quiz-option { display: flex; align-items: flex-start; gap: 14px; padding: 16px 18px; background: var(--paper); border: 1.5px solid var(--ink); cursor: pointer; transition: all 0.2s; text-align: left; font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.5; color: var(--ink); }
.quiz-option:hover:not(.disabled) { background: var(--ink); color: var(--paper); }
.quiz-option:hover:not(.disabled) .quiz-option-letter { background: var(--paper); color: var(--ink); }
.quiz-option-letter { flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; background: var(--ink); color: var(--paper); display: flex; align-items: center; justify-content: center; font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 700; }
.quiz-option.correct { background: var(--gold); color: var(--ink); border-color: var(--accent-2); }
.quiz-option.correct .quiz-option-letter { background: var(--ink); color: var(--gold); }
.quiz-option.wrong { background: var(--accent); color: var(--paper); border-color: var(--accent); }
.quiz-option.wrong .quiz-option-letter { background: var(--paper); color: var(--accent); }
.quiz-option.disabled { cursor: not-allowed; }
.quiz-feedback { margin-top: 20px; padding: 16px 18px; background: var(--paper); border-left: 3px solid var(--accent); font-size: 14px; line-height: 1.6; display: none; }
.quiz-feedback.show { display: block; }
.quiz-result { text-align: center; padding: 40px 0; }
.quiz-score { font-family: 'Fraunces', serif; font-size: 64px; font-weight: 300; line-height: 1; color: var(--accent-2); margin-bottom: 12px; }
.quiz-score-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }

/* ============ ACTIONS ============ */
.action-cats { display: flex; gap: 8px; margin-bottom: 32px; flex-wrap: wrap; }
.action-cat-btn { padding: 10px 18px; background: transparent; border: 1.5px solid var(--ink); font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.action-cat-btn.active, .action-cat-btn:hover { background: var(--ink); color: var(--paper); }
.actions-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.actions-pager { display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 28px; font-family: 'JetBrains Mono', monospace; font-size: 13px; }
.actions-pager-btn { width: 40px; height: 40px; background: transparent; border: 1.5px solid var(--ink); color: var(--ink); cursor: pointer; font-size: 18px; line-height: 1; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center; }
.actions-pager-btn:hover:not(:disabled) { background: var(--ink); color: var(--paper); }
.actions-pager-btn:disabled { opacity: 0.3; cursor: not-allowed; }
.actions-pager-info { font-weight: 600; letter-spacing: 0.05em; }
.actions-pager-total { color: var(--ink-light, #6b5d4f); font-weight: 400; margin-left: 6px; }
.action-card { padding: 24px; background: var(--paper); border: 1.5px solid var(--ink); display: flex; gap: 16px; align-items: flex-start; transition: all 0.2s; }
.action-card:hover { background: var(--paper-dark); transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--accent); }
.action-num { font-family: 'Fraunces', serif; font-size: 36px; font-weight: 700; font-style: normal; color: var(--accent); line-height: 1; flex-shrink: 0; width: 56px; }
.action-content { flex: 1; }
.action-title { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 700; line-height: 1.3; margin-bottom: 6px; }
.action-desc { font-size: 15px; font-weight: 300; line-height: 1.6; color: var(--muted); }

/* ============ JOURNAL ============ */
.journal-prompts-nav { display: flex; gap: 8px; margin-bottom: 24px; justify-content: center; }
.journal-dot { width: 36px; height: 36px; border: 1.5px solid var(--ink); display: flex; align-items: center; justify-content: center; font-family: 'JetBrains Mono', monospace; font-size: 13px; cursor: pointer; transition: all 0.2s; }
.journal-dot.active, .journal-dot:hover { background: var(--ink); color: var(--paper); }
.journal-prompt { display: none; max-width: 820px; margin: 0 auto; }
.journal-prompt.active { display: block; }
.journal-q { font-family: 'Fraunces', serif; font-size: clamp(22px, 3vw, 32px); font-weight: 600; font-style: normal; line-height: 1.3; margin-bottom: 20px; }
.journal-help { padding: 20px 24px; background: var(--paper-dark); border-left: 3px solid var(--accent); font-size: 15px; line-height: 1.6; margin-bottom: 24px; font-style: normal; }
.journal-textarea { width: 100%; min-height: 200px; padding: 20px; border: 1.5px solid var(--ink); background: var(--paper); font-family: 'Fraunces', serif; font-size: 17px; line-height: 1.6; resize: vertical; }
.journal-textarea:focus { outline: none; border-color: var(--accent); }

/* ============ FOOTER ============ */
.footer { padding: 80px 8% 60px; background: var(--ink); color: var(--paper); text-align: center; }
.footer-quote { font-family: 'Fraunces', serif; font-size: clamp(22px, 3vw, 32px); font-weight: 300; font-style: normal; max-width: 800px; margin: 0 auto 32px; line-height: 1.3; }
.footer-author { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); }
.footer-back { margin-top: 48px; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
.footer-back a { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--paper); text-decoration: none; padding: 12px 24px; border: 1px solid rgba(245, 237, 224, 0.3); transition: all 0.2s; }
.footer-back a:hover { background: var(--accent); border-color: var(--accent); }
.footer-meta { margin-top: 60px; padding-top: 32px; border-top: 1px solid rgba(245, 240, 230, 0.2); font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--muted); }

@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; padding: 24px 6% 40px; }
  .hero-visual { height: 400px; order: -1; }
  .hero-loop { width: 320px; height: 320px; }
  .section { padding: 60px 6%; }
  .laws-grid { grid-template-columns: 1fr; }
  .loop-diagram { grid-template-columns: 1fr 1fr; }
  .identity-grid { grid-template-columns: 1fr; gap: 12px; }
  .identity-arrow { transform: rotate(90deg); }
  .nav-links { gap: 12px; font-size: 11px; }
  .nav-links a:not(.always-show) { display: none; }
  .breadcrumb-bar { padding: 80px 6% 0; }
}
@media (max-width: 600px) {
  .nav-bar { padding: 12px 16px; }
  .footer { padding: 60px 6% 40px; }
  .loop-diagram { grid-template-columns: 1fr; }
}

/* ============ COMMENTS ============ */
.comment-form-wrap { max-width: 760px; margin-bottom: 48px; }
.comment-form { background: var(--paper); border: 2px solid var(--ink); padding: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
.comment-form input[type="text"], .comment-form input[type="email"], .comment-form textarea { width: 100%; padding: 12px 14px; border: 1.5px solid var(--ink); background: var(--paper-dark); font-family: 'Fraunces', Georgia, serif; font-size: 16px; line-height: 1.5; color: var(--ink); resize: vertical; }
.comment-form input:focus, .comment-form textarea:focus { outline: none; border-color: var(--accent); background: var(--paper); }
.form-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 14px; flex-wrap: wrap; gap: 12px; }
.form-hint { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; color: var(--muted); }
.form-submit { padding: 12px 24px; background: var(--ink); color: var(--paper); border: none; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.form-submit:hover { background: var(--accent); }
.form-submit:disabled { opacity: 0.5; cursor: not-allowed; }
.form-message { margin-top: 16px; padding: 14px 18px; font-size: 15px; line-height: 1.5; display: none; }
.form-message.show { display: block; }
.form-message.success { background: var(--paper-dark); border-left: 3px solid var(--gold); color: var(--ink); }
.form-message.error { background: var(--paper-dark); border-left: 3px solid var(--accent); color: var(--accent); }
.comments-list { max-width: 760px; }
.comments-loading, .comments-empty { font-size: 16px; color: var(--muted); padding: 24px 0; font-style: normal; }
.comment-item { padding: 20px 24px; border-left: 2px solid var(--ink); background: var(--paper); margin-bottom: 14px; transition: border-color 0.2s; }
.comment-item:hover { border-left-color: var(--accent); }
.comment-item.is-reply { margin-left: 36px; border-left-color: var(--gold); background: var(--paper-dark); }
.comment-head { display: flex; gap: 12px; align-items: baseline; margin-bottom: 8px; flex-wrap: wrap; }
.comment-author { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 700; color: var(--ink); }
.comment-time { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 0.05em; }
.comment-body { font-size: 16px; line-height: 1.6; color: var(--ink); white-space: pre-wrap; word-break: break-word; }
.comment-actions { margin-top: 10px; }
.comment-reply-btn { background: none; border: none; padding: 0; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); cursor: pointer; }
.comment-reply-btn:hover { text-decoration: underline; }
.reply-indicator { display: inline-block; padding: 4px 10px; background: var(--paper-dark); border: 1px solid var(--ink); font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; }
.reply-indicator button { background: none; border: none; cursor: pointer; color: var(--accent); margin-left: 8px; font-weight: 700; }
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } .comment-item.is-reply { margin-left: 16px; } }

</style>
