</main>
<script>
const flashcards = [
  { q: "Vòng lặp thói quen (habit loop) có 4 giai đoạn nào? Vai trò của mỗi giai đoạn?", a: "Cue (tín hiệu — não chú ý), Craving (khao khát — não muốn), Response (phản ứng — cơ thể làm), Reward (phần thưởng — não nhớ). Mỗi thói quen tốt hay xấu đều đi qua đủ 4 giai đoạn." },
  { q: "Bốn quy luật của thay đổi hành vi (4 Laws) là gì?", a: "Law #1: Make it Obvious (Rõ). Law #2: Make it Attractive (Hấp dẫn). Law #3: Make it Easy (Dễ). Law #4: Make it Satisfying (Thỏa mãn). Để bỏ thói quen xấu — đảo ngược tất cả: vô hình, không hấp dẫn, khó, không thỏa mãn." },
  { q: "Sự khác biệt cốt lõi giữa Mục tiêu và Hệ thống?", a: "Mục tiêu nói về kết quả bạn muốn. Hệ thống nói về quy trình dẫn đến kết quả. Mục tiêu cho hướng — hệ thống cho tiến triển. Bạn không vươn lên với mục tiêu; bạn rớt xuống với hệ thống của mình." },
  { q: "Ý định thực hiện (implementation intention) là gì? Hiệu quả ra sao?", a: "Công thức: 'Tôi sẽ [HÀNH VI] vào [THỜI GIAN] tại [ĐỊA ĐIỂM].' Nghiên cứu: nhóm có ý định cụ thể đi tập 91% — nhóm chỉ 'cố gắng' 39%. Cụ thể đánh bại quyết tâm. Tâm trí cần địa chỉ rõ, không phải ước mơ mờ." },
  { q: "Xếp chồng thói quen (habit stacking) là gì? Áp dụng thế nào?", a: "Công thức: 'Sau khi [thói quen cũ], tôi sẽ [thói quen mới].' Ví dụ: Sau khi pha cà phê sáng, tôi sẽ thiền 2 phút. Tận dụng thói quen đã có làm tín hiệu cho thói quen mới — không cần xây tín hiệu từ đầu." },
  { q: "Quy tắc 2 phút — và vì sao nó hiệu quả?", a: "Rút mọi thói quen xuống phiên bản 2 phút: 'Đọc 30 phút' → 'Đọc 1 trang'. 'Tập 1 giờ' → 'Mặc đồ tập'. Mục đích không phải làm tí — mà để không bỏ ngày nào, để khẳng định danh tính. Identity là kẻ chiến thắng dài hạn." },
  { q: "Thói quen dựa trên danh tính (identity-based habits) — khác outcome-based ở điểm nào?", a: "Dựa trên kết quả (outcome-based): 'Tôi muốn đọc 30 cuốn sách' → bỏ khi không thấy kết quả. Dựa trên danh tính (identity-based): 'Tôi là người đọc' → mỗi trang là một phiếu bầu. Khi danh tính thay đổi, hành vi tự đến — không cần ý chí." },
  { q: "Vì sao môi trường thắng động lực?", a: "Hành vi đi theo đường ít ma sát. Trái cây trên bàn = ăn nhiều hơn 200%. Phone trên giường = lướt 90 phút trước khi ngủ. Bạn không lười — bạn đang đi theo độ dốc. Đổi độ dốc, đổi hành vi." },
  { q: "Plateau of Latent Potential là gì? Vì sao đa số bỏ?", a: "Khi xây thói quen, kết quả không tuyến tính — bạn lao động nhiều tháng không thấy gì, rồi đột ngột bùng nổ. Đây là 'thềm trễ tiềm năng'. Đa số bỏ trong giai đoạn này vì kỳ vọng kết quả ngay. Phải tin vào hệ thống khi mắt chưa thấy gì." },
  { q: "vùng Goldilocks Rule — vùng nào là vùng tăng tiến?", a: "Không quá dễ (chán), không quá khó (nản) — vừa khó hơn khả năng hiện tại một chút. Đây là vùng tăng tiến mạnh nhất. Khi thói quen đã thành thạo, phải tăng độ khó — nếu không sẽ tự động hóa và ngừng cải thiện." }
];

const quizQuestions = [
  {
    q: "Bạn muốn xây thói quen tập thể dục mỗi sáng. Đã thử 3 tháng vẫn bỏ. Theo Clear, sai lầm phổ biến nhất là gì?",
    options: [
      "Không đủ động lực — cần đọc thêm sách self-help",
      "Đặt mục tiêu thay vì xây hệ thống và danh tính. 'Tôi muốn giảm 5kg' khác 'Tôi là người tập thể dục' — câu sau sống lâu hơn",
      "Cần phòng tập đắt tiền hơn",
      "Chưa thử app theo dõi"
    ],
    correct: 1,
