<circle cx="140" cy="300" fill="var(--accent)" r="22" stroke="var(--accent)" stroke-width="3"></circle>
<text fill="var(--paper)" font-family="Fraunces, serif" font-size="18" font-weight="700" text-anchor="middle" x="140" y="308">04</text>
<text fill="var(--ink)" font-family="Fraunces, serif" font-size="22" font-weight="700" text-anchor="middle" x="300" y="50">Rõ ràng</text>
<text fill="var(--muted)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="3" text-anchor="middle" x="300" y="75">LAW #1</text>
<text fill="var(--ink)" font-family="Fraunces, serif" font-size="22" font-weight="700" text-anchor="start" x="495" y="296">Hấp dẫn</text>
