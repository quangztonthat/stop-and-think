let currentCard = 0;
let knownCards = new Set();
let currentQuiz = 0;
let quizScore = 0;
let quizAnswered = false;

function renderCard() {
  document.getElementById('cardQuestion').textContent = flashcards[currentCard].q;
  document.getElementById('cardAnswer').textContent = flashcards[currentCard].a;
  document.getElementById('cardCurrent').textContent = currentCard + 1;
  document.getElementById('cardTotal').textContent = flashcards.length;
  document.getElementById('cardKnown').textContent = knownCards.size;
  document.getElementById('flashcard').classList.remove('flipped');
}
function flipCard() { document.getElementById('flashcard').classList.toggle('flipped'); }
function nextCard() { currentCard = (currentCard + 1) % flashcards.length; renderCard(); }
function prevCard() { currentCard = (currentCard - 1 + flashcards.length) % flashcards.length; renderCard(); }
function markKnown() { knownCards.add(currentCard); document.getElementById('cardKnown').textContent = knownCards.size; setTimeout(nextCard, 300); }
function markUnknown() { knownCards.delete(currentCard); document.getElementById('cardKnown').textContent = knownCards.size; setTimeout(nextCard, 300); }

function renderQuiz() {
  if (currentQuiz >= quizQuestions.length) { showQuizResult(); return; }
  const q = quizQuestions[currentQuiz];
  document.getElementById('quizQuestion').innerHTML = q.q;
  document.getElementById('quizCurrent').textContent = currentQuiz + 1;
  document.getElementById('quizTotal').textContent = quizQuestions.length;
  document.getElementById('quizScore').textContent = quizScore;
  document.getElementById('quizBarFill').style.width = ((currentQuiz + 1) / quizQuestions.length * 100) + '%';
  const optionsEl = document.getElementById('quizOptions');
  optionsEl.innerHTML = '';
  const letters = ['A', 'B', 'C', 'D'];
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option';
    btn.innerHTML = '<span class="quiz-option-letter">' + letters[i] + '</span><span>' + opt + '</span>';
    btn.onclick = () => answerQuiz(i);
    optionsEl.appendChild(btn);
  });
  document.getElementById('quizFeedback').classList.remove('show');
  document.getElementById('quizNext').style.display = 'none';
  quizAnswered = false;
}
function answerQuiz(idx) {
  if (quizAnswered) return;
  quizAnswered = true;
  const q = quizQuestions[currentQuiz];
  const options = document.querySelectorAll('.quiz-option');
  options.forEach((opt, i) => {
    opt.classList.add('disabled');
    if (i === q.correct) opt.classList.add('correct');
    if (i === idx && i !== q.correct) opt.classList.add('wrong');
  });
  if (idx === q.correct) quizScore++;
  document.getElementById('quizScore').textContent = quizScore;
  const fb = document.getElementById('quizFeedback');
  fb.innerHTML = q.explain;
  fb.classList.add('show');
  document.getElementById('quizNext').style.display = 'inline-block';
  if (currentQuiz === quizQuestions.length - 1) document.getElementById('quizNext').textContent = 'Xem kết quả →';
}
function nextQuestion() { currentQuiz++; renderQuiz(); }
function showQuizResult() {
  const total = quizQuestions.length;
  const pct = Math.round(quizScore / total * 100);
  let label, msg;
  if (pct >= 90) { label = 'Atomic mindset'; msg = 'Tuyệt. Apply: pick 1 identity habit, dùng 4 quy luật, track 30 ngày.'; }
  else if (pct >= 70) { label = 'Hiểu khá tốt'; msg = 'Khá. Đọc lại 4 quy luật + Habit Stacking + 2-Minute Rule.'; }
  else if (pct >= 50) { label = 'Đang trên đường'; msg = 'Khung sườn có. Đọc lại Identity-based habits + 1% rule.'; }
  else { label = 'Cần ôn lại'; msg = 'Đọc lại Phần 1+2. Đặc biệt: 4 luật + Plateau of Latent Potential.'; }
  document.getElementById('quizContainer').innerHTML = '<div class="quiz-result"><div class="quiz-score">' + quizScore + '/' + total + '</div><div class="quiz-score-label">' + label + '</div><p style="margin: 32px auto; max-width: 500px; font-size: 17px; line-height: 1.5;">' + msg + '</p><button class="fcq-btn accent" onclick="resetQuiz()">Làm lại quiz</button></div>';
}
function resetQuiz() {
  currentQuiz = 0; quizScore = 0;
  document.getElementById('quizContainer').innerHTML = '<div class="quiz-progress"><span>Câu hỏi <span id="quizCurrent">1</span> / <span id="quizTotal">' + quizQuestions.length + '</span></span><span>Điểm: <span id="quizScore">0</span></span></div><div class="quiz-bar"><div class="quiz-bar-fill" id="quizBarFill" style="width: ' + (100/quizQuestions.length) + '%"></div></div><div class="quiz-question" id="quizQuestion"></div><div class="quiz-options" id="quizOptions"></div><div class="quiz-feedback" id="quizFeedback"></div><div style="display: flex; justify-content: flex-end; margin-top: 24px;"><button class="fcq-btn accent" id="quizNext" onclick="nextQuestion()" style="display: none;">Câu tiếp →</button></div>';
  renderQuiz();
}

const ACTIONS_PER_PAGE = 6;
let actionsCurrentPage = 1;
let actionsCurrentFilter = 'all';

function renderActions(filter = 'all') {
  actionsCurrentFilter = filter;
  const filtered = actions.filter(a => filter === 'all' || a.cat === filter);
  const totalPages = Math.max(1, Math.ceil(filtered.length / ACTIONS_PER_PAGE));
  if (actionsCurrentPage > totalPages) actionsCurrentPage = 1;
  const start = (actionsCurrentPage - 1) * ACTIONS_PER_PAGE;
  const slice = filtered.slice(start, start + ACTIONS_PER_PAGE);

  const grid = document.getElementById('actionsGrid');
  grid.innerHTML = '';
  slice.forEach(a => {
    const div = document.createElement('div');
    div.className = 'action-card';
    div.innerHTML = `
      <div class="action-num">${String(a.num).padStart(2, '0')}</div>
      <div class="action-content">
        <div class="action-title">${a.title}</div>
        <div class="action-desc">${a.desc}</div>
      </div>
    `;
    grid.appendChild(div);
  });

  renderActionsPager(totalPages, filtered.length);
}

function renderActionsPager(totalPages, totalItems) {
  let pager = document.getElementById('actionsPager');
  if (!pager) {
    pager = document.createElement('div');
    pager.id = 'actionsPager';
    pager.className = 'actions-pager';
    const grid = document.getElementById('actionsGrid');
    grid.parentNode.insertBefore(pager, grid.nextSibling);
  }
  if (totalPages <= 1) {
    pager.innerHTML = '';
    pager.style.display = 'none';
    return;
  }
  pager.style.display = '';
  pager.innerHTML = `
    <button class="actions-pager-btn" ${actionsCurrentPage === 1 ? 'disabled' : ''} onclick="changeActionsPage(-1)" aria-label="Trang truoc">&larr;</button>
    <span class="actions-pager-info">${actionsCurrentPage} / ${totalPages} <span class="actions-pager-total">(${totalItems} muc)</span></span>
    <button class="actions-pager-btn" ${actionsCurrentPage === totalPages ? 'disabled' : ''} onclick="changeActionsPage(1)" aria-label="Trang sau">&rarr;</button>
  `;
}

function changeActionsPage(delta) {
  actionsCurrentPage += delta;
  renderActions(actionsCurrentFilter);
}

function filterActions(cat, btn) {
  document.querySelectorAll('.action-cat-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  actionsCurrentPage = 1;
  renderActions(cat);
}

function renderPrompts() {
  const container = document.getElementById('promptsContainer');
  journalPrompts.forEach((p, i) => {
    const div = document.createElement('div');
    div.className = 'journal-prompt' + (i === 0 ? ' active' : '');
    div.id = `prompt-${i}`;
    div.innerHTML = `
      <div class="journal-q">${i + 1}. ${p.q}</div>
      <div class="journal-help">💡 Gợi ý: ${p.help}</div>
      <textarea class="journal-textarea" placeholder="Viết câu trả lời của bạn ở đây..."></textarea>
    `;
    container.appendChild(div);
  });
}

function switchPrompt(i, dot) {
  document.querySelectorAll('.journal-dot').forEach(d => d.classList.remove('active'));
  dot.classList.add('active');
  document.querySelectorAll('.journal-prompt').forEach(p => p.classList.remove('active'));
  document.getElementById(`prompt-${i}`).classList.add('active');
}

function scrollTo2(id) {
  const el = document.getElementById(id);
  if (el) window.scrollTo({ top: el.offsetTop - 80, behavior: 'smooth' });
}

window.addEventListener('scroll', () => {
  const total = document.documentElement.scrollHeight - window.innerHeight;
  const pct = (window.scrollY / total) * 100;
  document.getElementById('progressBar').style.width = pct + '%';
});

renderCard();
renderQuiz();
renderActions();
renderPrompts();
</script>
<script>
(function() {
  const COMMENTS_PAGE_ID = "atomic-habits";
  async function loadComments() {
    const list = document.getElementById('commentsList');
    if (!list) return;
    list.innerHTML = '<div class="comments-loading">Đang tải comment...</div>';
    try {
      const res = await fetch('/api/comments?page=' + COMMENTS_PAGE_ID);
      if (!res.ok) throw new Error('fetch failed');
      const data = await res.json();
      renderCommentsList(data.comments || []);
    } catch (e) {
      list.innerHTML = '<div class="comments-empty">Không tải được comment. Thử lại sau.</div>';
    }
  }
  function renderCommentsList(items) {
    const list = document.getElementById('commentsList');
    if (!items.length) {
      list.innerHTML = '<div class="comments-empty">Chưa có comment nào — bạn là người đầu tiên.</div>';
      return;
    }
    const byId = {};
    items.forEach(c => { c.replies = []; byId[c.id] = c; });
    const roots = [];
    items.forEach(c => {
      if (c.parent_id && byId[c.parent_id]) byId[c.parent_id].replies.push(c);
      else roots.push(c);
    });
    list.innerHTML = roots.map(c => renderNode(c, false)).join('');
  }
  function renderNode(c, isReply) {
    const replies = (c.replies || []).map(r => renderNode(r, true)).join('');
    return '<div class="comment-item ' + (isReply ? 'is-reply' : '') + '" id="comment-' + c.id + '"><div class="comment-head"><span class="comment-author">' + esc(c.author_name) + '</span><span class="comment-time">' + fmtTime(c.created_at) + '</span></div><div class="comment-body">' + esc(c.content) + '</div><div class="comment-actions"><button class="comment-reply-btn" onclick="window.__cmt_setReply(' + c.id + ', ' + JSON.stringify(c.author_name).replace(/"/g, '&quot;') + ')">↳ Trả lời</button></div></div>' + replies;
  }
  window.__cmt_setReply = function(id, name) {
    document.getElementById('cf-parent').value = id;
    document.getElementById('replyIndicator').style.display = 'inline-block';
    document.getElementById('replyTo').textContent = name;
    document.getElementById('cf-content').focus();
    document.getElementById('comments').scrollIntoView({behavior: 'smooth', block: 'start'});
  };
  function cancelReply() {
    document.getElementById('cf-parent').value = '';
    document.getElementById('replyIndicator').style.display = 'none';
  }
  function fmtTime(unix) {
    const d = new Date(unix * 1000);
    const diff = Date.now()/1000 - unix;
    if (diff < 60) return 'vừa xong';
    if (diff < 3600) return Math.floor(diff/60) + ' phút trước';
    if (diff < 86400) return Math.floor(diff/3600) + ' giờ trước';
    if (diff < 604800) return Math.floor(diff/86400) + ' ngày trước';
    return d.toLocaleDateString('vi-VN');
  }
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
  const form = document.getElementById('commentForm');
  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const submitBtn = document.getElementById('cf-submit');
      const msg = document.getElementById('cf-message');
      msg.className = 'form-message';
      const payload = {
        pageId: COMMENTS_PAGE_ID,
        name: document.getElementById('cf-name').value.trim(),
        email: document.getElementById('cf-email').value.trim(),
        content: document.getElementById('cf-content').value.trim(),
        parentId: document.getElementById('cf-parent').value || null,
        website: document.getElementById('cf-website').value
      };
      if (!payload.name || !payload.email || !payload.content) {
        msg.textContent = 'Vui lòng nhập đủ tên, email, nội dung.';
        msg.classList.add('show', 'error');
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = 'Đang gửi...';
      try {
        const res = await fetch('/api/comments', {
          method: 'POST',
          headers: {'content-type': 'application/json'},
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Lỗi gửi');
        msg.textContent = data.message || 'Đã gửi. Check email để xác nhận.';
        msg.classList.add('show', 'success');
        document.getElementById('cf-content').value = '';
        cancelReply();
      } catch (err) {
        msg.textContent = err.message || 'Lỗi gửi comment. Thử lại sau.';
        msg.classList.add('show', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Gửi comment →';
      }
    });
    document.getElementById('replyCancel').addEventListener('click', cancelReply);
    loadComments();
  }
})();
</script>
