  { num: 3, cat: 'obvious', title: 'Audit môi trường: bỏ tín hiệu xấu, đặt tín hiệu tốt', desc: 'Đi quanh nhà 1 lần. Liệt kê: tín hiệu của thói quen nào? Phone trên giường = lướt mạng. Snack trong tầm tay = ăn vặt. Sách trên bàn = đọc. Đổi 5 thứ trong tuần này.' },
  { num: 4, cat: 'obvious', title: 'Đặt sách/đồ tập/dụng cụ thiền ở nơi không thể tránh', desc: 'Sách trên gối ngủ. Đồ tập trên ghế cạnh giường. Cốc nước trên bàn làm việc. Mục tiêu: tín hiệu nằm trên đường di chuyển tự nhiên — không thể quên.' },
  { num: 5, cat: 'obvious', title: 'Làm "Habits Scorecard": list tất cả thói quen hiện tại', desc: 'Liệt kê mọi thứ bạn làm tự động trong ngày: thức dậy, kiểm tra phone, pha cà phê, lướt feed... Đánh dấu +/-/= cho từng cái. Bạn không thể đổi cái mình không nhận thức được.' },
  { num: 6, cat: 'attractive', title: 'Áp dụng temptation bundling — gắn việc cần với việc thích', desc: 'Công thức: "Tôi chỉ [việc thích] khi đang [việc cần]." Chỉ xem Netflix khi đang đạp xe đứng yên. Chỉ nghe podcast yêu thích khi đi bộ. Não tiết dopamine vì kỳ vọng — buộc nó về phía đúng.' },
  { num: 7, cat: 'attractive', title: 'Gia nhập 1 cộng đồng nơi thói quen mới là chuẩn', desc: 'Muốn đọc nhiều — vào book club. Muốn chạy — vào nhóm chạy. Muốn viết — vào nhóm viết. Bạn bắt chước 3 nhóm: thân cận, đông đảo, quyền lực. Đặt thói quen mới vào nhóm "đông đảo" thân cận.' },
  { num: 8, cat: 'attractive', title: 'Reframe: đổi từ "Tôi phải" sang "Tôi được"', desc: 'Đổi cách nói: "Tôi PHẢI tập" → "Tôi ĐƯỢC tập". "Tôi PHẢI làm việc" → "Tôi ĐƯỢC làm việc". Cùng hành động, cùng cảm xúc khác. Nhiều người trên thế giới mơ được làm cái bạn coi là gánh nặng.' },
  { num: 9, cat: 'attractive', title: 'Tạo "ritual" 30 giây trước thói quen tốt', desc: 'Trước khi tập: bật bài hát yêu thích. Trước khi viết: pha trà yêu thích. Não kết nối ritual với cảm giác tốt — tạo craving cho việc làm sau đó. Sau 2 tuần, ritual khởi động chính nó.' },
  { num: 10, cat: 'easy', title: 'Áp dụng Quy tắc 2 phút: rút thói quen xuống phiên bản nhỏ nhất', desc: '"Đọc 30 phút" → "Đọc 1 trang". "Chạy 5km" → "Mặc đồ chạy bước ra cửa". "Viết blog" → "Mở Word, gõ 1 câu". Mục tiêu: không bỏ ngày nào. Lượng tự đến khi danh tính đã chắc.' },
  { num: 11, cat: 'easy', title: 'Giảm ma sát thói quen tốt — từng bước', desc: 'Liệt kê 5 bước phải làm để bắt đầu thói quen tốt. Bỏ bớt 2 bước. Đặt đồ chạy cạnh giường = bỏ bước "tìm". Để app đọc trên màn hình chính = bỏ bước "tìm app".' },
  { num: 12, cat: 'easy', title: 'Tăng ma sát thói quen xấu — từng bước', desc: 'Phone ra ngoài phòng ngủ. Đăng xuất các app mạng xã hội. Snack lên kệ cao. Mỗi bước thêm vào trước thói quen xấu = giảm 30-50% tỷ lệ làm.' },
  { num: 13, cat: 'easy', title: 'Tạo "commitment device" cho 1 mục tiêu lớn', desc: 'Trả tiền lớp học trước 6 tháng. Hợp đồng với HLV cá nhân. Cài app phạt $20 mỗi ngày bỏ tập. Ràng buộc tương lai bằng quyết định hiện tại — khi bạn còn tỉnh táo.' },
  { num: 14, cat: 'easy', title: 'Tự động hóa 1 việc mỗi tháng', desc: 'Tiết kiệm tự động (chuyển đầu tháng). Block website mặc định. Auto-reply email theo giờ. Một lần thiết lập = nhiều ngày kết quả. Đừng phụ thuộc ý chí cho việc có thể tự động.' },
  { num: 15, cat: 'satisfying', title: 'Bắt đầu Habit Tracker — đánh dấu mỗi ngày', desc: 'Lịch giấy treo tường. App đơn giản. Đánh ✓ mỗi ngày làm. Quy tắc Seinfeld: "Đừng phá xích." Não thích thấy chuỗi liên tục — bản thân nó là phần thưởng.' },
  { num: 16, cat: 'satisfying', title: 'Áp dụng "Không bao giờ bỏ 2 ngày liên tiếp"', desc: 'Lỡ 1 ngày = tai nạn. Lỡ 2 ngày = thói quen mới. Không phải về làm hoàn hảo — về quay lại nhanh sau khi lỡ. Người chuyên nghiệp = người quay lại nhanh nhất.' },
  { num: 17, cat: 'satisfying', title: 'Tìm 1 đối tác chịu trách nhiệm', desc: 'Người chứng kiến tạo hậu quả xã hội tức thì. Báo cáo hàng tuần với 1 người. Đặt cọc 100k cho mỗi ngày bỏ. Hậu quả tức thì + xã hội = mạnh nhất.' },
  { num: 18, cat: 'satisfying', title: 'Review hàng tháng: cái gì hoạt động, cái gì không', desc: 'Cuối tháng: 30 phút. 3 câu hỏi: (1) Cái gì hoạt động? (2) Cái gì không? (3) Tôi học được gì? Không có review = thói quen tự động không cải thiện. Việc dừng lại nhìn nhận có chủ đích là bí quyết đi từ tốt sang xuất sắc.' }
];

