# ═══════════════════════════════════════════════════════
# Stop & Think — .gitignore
# ═══════════════════════════════════════════════════════

# ─── Sách bản quyền ───
library/
*.epub
_books_raw/

# ─── Tài liệu nội bộ ───
docs/
GIT_SETUP.md

# ─── Branding/IG launch (cá nhân, không cần lên web) ───
branding/

# ─── Workflow files (chỉ dùng local) ───
BOOKS_QUEUE.md
BOOKS_QUEUE.xlsx
GLOSSARY.xlsx
_apply_glossary.py

# ─── Build scripts (regenerate khi cần) ───
_build_books.py
_build_glossary.py
_build_glossary_v2.py
_regen_feed_index.py
_glossary_data.json

# ─── Local development tools ───
edit-mode.js

# ─── Database setup (chạy 1 lần khi init D1) ───
schema.sql
migrations/

# ─── Audit reports ───
AUDIT_REPORT_*.txt

# ─── Excel/Office locks ───
.~lock.*
~$*

# ─── Editor ───
.vscode/

# ─── Misc local ───
upload.bat

# ─── Windows ───
Thumbs.db
desktop.ini

# ─── Backup ───
*.bak
*~

# ─── Logs ───
*.log

# ─── Python ───
__pycache__/
*.pyc
.venv/
venv/

# ─── Node ───
node_modules/
.npm/

# ─── Local git scratch ───
.git/index.lock
