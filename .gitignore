# ═══════════════════════════════════════════════════════
# Stop & Think — .gitignore
# ═══════════════════════════════════════════════════════

# ─── Sách bản quyền ───
library/
*.epub
_books_raw/

# ─── Tài liệu nội bộ ───
docs/
GIT_SETUP.md

# ─── Branding/IG launch (cá nhân, không cần lên web) ───
branding/

# ─── Workflow files (chỉ dùng local) ───
# Note: docs/ already gitignored above → docs/glossary/, docs/opinions/, docs/books-queue/ inherit
# Còn lại trong root: build scripts cho one-time regen

# ─── Build scripts (regenerate khi cần) ───
_build_books.py
_regen_feed_index.py

# ─── Local development tools ───
edit-mode.js

# ─── Database setup (chạy 1 lần khi init D1) ───
schema.sql
migrations/

# ─── Audit reports ───
AUDIT_REPORT_*.txt

# ─── Excel/Office locks ───
.~lock.*
~$*

# ─── Editor ───
.vscode/

# ─── Misc local ───
upload.bat

# ─── Windows ───
Thumbs.db
desktop.ini

# ─── Backup ───
*.bak
*~
_recovery/

# ─── Logs ───
*.log

# ─── Python ───
__pycache__/
*.pyc
.venv/
venv/

# ─── Node ───
node_modules/
.npm/

# ─── Local git scratch ───
.git/index.lock
